<article class="post">
  <header class="post-head">
    <div class="meta">
      <a class="sec-badge sec-$slug" href="$section_url">$section_name</a>
      <time>$date</time>
    </div>
    <h1>$title</h1>
    $tags_html
    $source_html
  </header>
  <div class="post-body">$body</div>
  <footer class="post-foot">
    <a href="$section_url">← 返回 $section_name</a>
    <a href="/">首页</a>
  </footer>
</article>
